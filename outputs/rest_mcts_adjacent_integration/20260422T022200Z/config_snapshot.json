{
  "contract_config_path": "configs/rest_mcts_adjacent_comparison_contract_v2.json",
  "contract": {
    "baseline_key": "rest_mcts",
    "canonical_title": "ReST-MCTS*: LLM Self-Training via Process Reward Guided Tree Search",
    "integration_mode": "official_adjacent_partial_runnable_stable_lane",
    "official_sources": {
      "official_repo": "https://github.com/THUDM/ReST-MCTS",
      "official_project_page": "https://rest-mcts.github.io",
      "neurips_2024_page": "https://proceedings.neurips.cc/paper_files/paper/2024/hash/76ec4dc30e9faaf0e4b6093eaa377218-Abstract-Conference.html",
      "arxiv_abs": "https://arxiv.org/abs/2406.03816",
      "arxiv_pdf": "https://arxiv.org/pdf/2406.03816.pdf"
    },
    "benchmark_contract": {
      "canonical_benchmark_family": "MATH",
      "default_expected_split": "test",
      "stable_adjacent_subset": [
        {
          "subset_id": "math_test_import_contract",
          "expected_dataset": "math",
          "results_path": "tests/fixtures/rest_mcts_import_valid",
          "minimum_rows": 2,
          "required_search_modes": [
            "mcts"
          ],
          "comparability_scope": "adjacent_only"
        }
      ]
    },
    "budget_and_compute_normalization": {
      "primary_rule": "Report comparisons only within fixed declared iteration_limit and branch settings for each imported row.",
      "required_metadata_fields": [
        "search.iteration_limits",
        "search.branch_factors",
        "self_training.iterations_completed"
      ],
      "cross_method_claim_guardrail": "Do not claim control-equivalent compute normalization versus frontier-allocation controllers; report as adjacent-only with explicit declared search budget fields."
    },
    "model_and_path_requirements": {
      "required_metadata_fields": [
        "models.policy_model_family",
        "models.value_model_family",
        "upstream.repo_url",
        "upstream.paper_url"
      ],
      "official_repo_layout_required": [
        "README.md",
        "MCTS/task.py",
        "evaluate.py",
        "self_train/self_train_dpo.py",
        "PRM/train_VM_mistral.py"
      ],
      "official_repo_path_optional": true
    },
    "artifact_requirements": {
      "required_outputs": [
        "status.json",
        "comparison_readiness.json",
        "summary.json",
        "summary.md",
        "manifest.json",
        "config_snapshot.json",
        "commands_snapshot.txt",
        "comparison_ready_rows.csv"
      ],
      "optional_outputs": [
        "verification_report.json",
        "official_repo_structure.json"
      ],
      "output_family": "outputs/rest_mcts_adjacent_integration/<run_id>/"
    },
    "success_criteria": {
      "minimum_for_import_validated_adjacent": [
        "contract_file_present",
        "stable_subset_verified",
        "validator_status_valid",
        "adjacent_scope_enforced"
      ],
      "minimum_for_partial_runnable_adjacent": [
        "minimum_for_import_validated_adjacent",
        "official_repo_accessible_or_precloned",
        "official_layout_check_passed"
      ]
    },
    "allowed_claims": [
      "Official-source provenance is documented and validated against required links and repository structure.",
      "A stable adjacent runnable lane exists for a contract-bound MATH test import subset.",
      "Integration status is partial_runnable_adjacent with explicit adjacent_only scope."
    ],
    "not_allowed_claims": [
      "Full faithful in-repo reproduction of complete ReST-MCTS self-training pipeline.",
      "Direct control-equivalent comparison with frontier/action-native branch-allocation methods.",
      "Unqualified SOTA claims based on this adjacent integration lane."
    ]
  },
  "args": {
    "output_root": "/workspace/adaptive-reasoning-budget-allocation/outputs/rest_mcts_adjacent_integration",
    "official_repo_path": "/tmp/rest_mcts_upstream/ReST-MCTS",
    "skip_clone": false
  }
}
