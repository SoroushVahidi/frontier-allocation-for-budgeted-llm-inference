\@writefile{lot}{\contentsline {table}{\numberline {4}{\ignorespaces Pooled answer-ensemble baselines computed from the same per-example frontier, L1, S1, and TALE outputs. Pooled-4 uses a strict majority over four answers and falls back to the frontier answer on ties or all-different cases. External-3 uses majority vote over L1/S1/TALE with the fixed, deterministic TALE$\succ $S1$\succ $L1 tie fallback used by the main method; tie sensitivity is summarized in Table\nobreakspace  {}\ref  {tab:param_sensitivity}. Deltas and win/loss/tie counts compare Failure-Trace Allocator (FTA, implementation: FIX-2+FIX-4) to the pooled baseline.}}{12}{table.4}\protected@file@percent }
\newlabel{tab:pooled_ensemble}{{4}{12}{Pooled answer-ensemble baselines computed from the same per-example frontier, L1, S1, and TALE outputs. Pooled-4 uses a strict majority over four answers and falls back to the frontier answer on ties or all-different cases. External-3 uses majority vote over L1/S1/TALE with the fixed, deterministic TALE$\succ $S1$\succ $L1 tie fallback used by the main method; tie sensitivity is summarized in Table~\ref {tab:param_sensitivity}. Deltas and win/loss/tie counts compare Failure-Trace Allocator (FTA, implementation: FIX-2+FIX-4) to the pooled baseline}{table.4}{}}
