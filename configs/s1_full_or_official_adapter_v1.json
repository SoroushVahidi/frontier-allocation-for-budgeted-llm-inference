{
  "version": "s1_full_or_official_adapter_v1",
  "mode": "full_or_official",
  "provenance": {
    "paper": "https://aclanthology.org/2025.emnlp-main.1025/",
    "official_code": "https://github.com/simplescaling/s1",
    "intent": "Secondary path for full/official s1 reporting. Not apples-to-apples when post-training is included."
  },
  "model": {
    "use_openai_api": false,
    "provider": "openai",
    "name": "gpt-4.1-mini",
    "temperature": 0.2,
    "max_output_tokens": 180,
    "timeout_seconds": 45
  },
  "s1_budget_forcing": {
    "num_ignore_think_end": 1,
    "min_thinking_steps": 0,
    "wait_token": "Wait"
  },
  "dataset": {
    "name": "openai/gsm8k",
    "subset_size": 32,
    "seeds": [
      11,
      23,
      37
    ],
    "split": "test"
  },
  "budget": {
    "grid": [
      4,
      6,
      8
    ],
    "unit": "action",
    "action_to_token_equivalent": 64.0,
    "matching_policy": "Report internal action budgets and token-equivalent budgets. Keep full s1 results separately labeled."
  },
  "methods": {
    "include": [
      "adaptive_min_expand_1",
      "external_s1_budget_forcing"
    ],
    "adaptive_min_expand_grid": [
      1
    ]
  },
  "official": {
    "results_path": "",
    "contract_version": "s1_mode_b_official_import_v1",
    "required_package_files": [
      "metadata.json",
      "results.csv"
    ],
    "required_metadata_fields": [
      "source.type",
      "model.checkpoint",
      "dataset.name",
      "dataset.split",
      "prompt.template",
      "prompt.family",
      "budget.unit",
      "budget.settings",
      "token_accounting.prompt_tokens_field",
      "token_accounting.completion_tokens_field",
      "token_accounting.total_tokens_field",
      "decoding.temperature",
      "decoding.top_p",
      "decoding.max_new_tokens",
      "metrics.schema_version",
      "metrics.primary",
      "provenance.exported_at_utc",
      "provenance.source_uri",
      "provenance.artifact_id",
      "provenance.commit_or_version_if_available"
    ],
    "required_results_columns": [
      "mode",
      "source_type",
      "dataset",
      "split",
      "model_checkpoint",
      "prompt_family",
      "prompt_template",
      "budget_setting",
      "accuracy",
      "exact_match",
      "avg_token_cost",
      "temperature",
      "top_p",
      "max_new_tokens",
      "artifact_id",
      "commit_or_version"
    ],
    "status_policy": "If results_path is empty, MODE B is blocked. If provided, results must pass strict verification or import is rejected."
  },
  "metrics": {
    "primary": [
      "accuracy",
      "exact_match",
      "avg_token_cost_equivalent",
      "budget_adherence_rate",
      "budget_violation_rate",
      "budget_exhaustion_rate"
    ],
    "frontier": "Pareto frontier over (mean_avg_token_cost_equivalent, mean_accuracy)."
  },
  "output": {
    "root_dir": "outputs/s1_baseline"
  },
  "reproducibility": {
    "notes": "MODE B is official/full results import only with strict verification; this config does not claim local full s1 post-training reproduction."
  }
}
