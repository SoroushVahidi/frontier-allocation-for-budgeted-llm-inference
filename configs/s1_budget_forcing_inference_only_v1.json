{
  "version": "s1_inference_only_v1",
  "mode": "inference_only",
  "provenance": {
    "paper": "https://aclanthology.org/2025.emnlp-main.1025/",
    "official_code": "https://github.com/simplescaling/s1",
    "intent": "Primary apples-to-apples baseline: s1-style inference budget forcing on unchanged base model family."
  },
  "model": {
    "use_openai_api": false,
    "provider": "openai",
    "name": "gpt-4.1-mini",
    "temperature": 0.2,
    "max_output_tokens": 180,
    "timeout_seconds": 45
  },
  "s1_budget_forcing": {
    "num_ignore_think_end": 1,
    "min_thinking_steps": 0,
    "wait_token": "Wait"
  },
  "dataset": {
    "name": "openai/gsm8k",
    "subset_size": 32,
    "seeds": [11, 23, 37]
  },
  "budget": {
    "grid": [4, 6, 8],
    "unit": "action",
    "action_to_token_equivalent": 64.0,
    "matching_policy": "Use the same action budget grid for all methods and report token-equivalent conversion columns."
  },
  "methods": {
    "include": [
      "adaptive_min_expand_1",
      "reasoning_greedy",
      "self_consistency_3",
      "verifier_guided_search",
      "external_s1_budget_forcing"
    ],
    "adaptive_min_expand_grid": [1]
  },
  "metrics": {
    "primary": [
      "accuracy",
      "exact_match",
      "avg_token_cost_equivalent",
      "budget_adherence_rate",
      "budget_violation_rate",
      "budget_exhaustion_rate"
    ],
    "frontier": "Pareto frontier over (mean_avg_token_cost_equivalent, mean_accuracy)."
  },
  "output": {
    "root_dir": "outputs/s1_baseline"
  },
  "reproducibility": {
    "notes": "Deterministic seeds are fixed in config. Run manifest stores mode, dataset, budgets, and method list."
  }
}
