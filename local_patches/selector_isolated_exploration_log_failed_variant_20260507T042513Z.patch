+    @staticmethod
+    def _rate_ratio_question_cue(question: str) -> bool:
+        q = str(question or "").lower()
+        return bool(
+            re.search(
+                r"\brate\b|\bratio\b|\bunit rate\b|\bper\b|\beach\b|\bspeed\b|\bprice\b|\bshare\b|\bproportion\b",
+                q,
+            )
+        )
+
+    @staticmethod
+    def _question_quantity_bucket(question: str) -> str:
+        nums = re.findall(r"[-+]?\d+(?:\.\d+)?", str(question or "").replace(",", ""))
+        n = len(nums)
+        if n <= 1:
+            return "qnum_0_1"
+        if n <= 3:
+            return "qnum_2_3"
+        if n <= 5:
+            return "qnum_4_5"
+        return "qnum_6p"
+
+    def _compose_selector_isolated_exploration_question(self, question: str) -> str:
+        return (
+            f"{question}\n\n"
+            "Solve with unit-rate / equation-form reasoning. Return strict JSON with keys: action, equation, answer, confidence.\n"
+            "Rules:\n"
+            "1) action should be final when answer is known.\n"
+            "2) answer must be final numeric answer only.\n"
+            "3) equation should support the final numeric answer.\n"
+            "4) prefer explicit per-unit conversion when relevant.\n"
+        )
+
+    def _run_selector_isolated_exploration_attempt(
+        self, question: str, gold_answer: str, max_actions: int
+    ) -> tuple[str | None, int, list[dict[str, Any]]]:
+        branch = self.generator.init_branch("selector_isolated_exploration_0")
+        actions = 0
+        trace: list[dict[str, Any]] = []
+        prompt = self._compose_selector_isolated_exploration_question(question)
+        while actions < max_actions and not branch.is_done and not branch.is_pruned:
+            self.generator.expand(branch, prompt, gold_answer)
+            actions += 1
+            latest = branch.trace_events[-1] if branch.trace_events else {}
+            trace.append(
+                {
+                    "action": "expand",
+                    "branch_id": branch.branch_id,
+                    "prompt_text": str(latest.get("prompt_text", "")),
+                    "response_text": str(latest.get("response_text", "")),
+                    "reasoning_text": str(latest.get("reasoning_text", "")),
+                    "extracted_answer": str(latest.get("extracted_answer", "") or ""),
+                    "source_metadata": "selector_isolated_exploration_log",
+                }
+            )
+        ans = branch.predicted_answer
+        if (ans is None or not str(ans).strip()) and trace:
+            mined = extract_final_answer(str(trace[-1].get("reasoning_text") or ""))
+            if mined is not None and str(mined).strip():
+                ans = str(mined).strip()
+        return (str(ans).strip() if ans is not None and str(ans).strip() else None, actions, trace)
+
